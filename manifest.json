{
  "manifest_version": 3,
  "name": "Tabflow — AI Browser Workspace",
  "short_name": "Tabflow",
  "incognito": "spanning",
  "description": "Tabflow organizes tabs into intelligent workspaces, provides AI summaries, and lets you chat with your context.",
  "version": "1.0.0",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Tabflow"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "history",
    "activeTab",
    "scripting",
    "alarms",
    "sessions"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://openrouter.ai/*",
    "https://dpaste.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "commands": {
    "smart-launcher": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Smart Action Launcher"
    }
  }
}
